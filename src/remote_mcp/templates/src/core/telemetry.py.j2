from __future__ import annotations

import hashlib
import hmac
import logging
import logging.handlers
from datetime import datetime, timezone
from functools import lru_cache
from pathlib import Path
from typing import Any

from pydantic import BaseModel, Field

from src.config.settings import settings

logger = logging.getLogger(__name__)


class TelemetryEvent(BaseModel):
    timestamp: str = Field(default_factory=lambda: datetime.now(timezone.utc).isoformat())
    event_type: str  # tool_call, connection, auth_failure, rate_limit
    user_id: str | None = None
    tool_name: str | None = None
    success: bool | None = None
    error_type: str | None = None
    latency_ms: float | None = None
    response_size_bytes: int | None = None
    client_ip: str | None = None
    user_agent: str | None = None
    path: str | None = None
    extra: dict[str, Any] = Field(default_factory=dict)


def hash_token(token: str) -> str:
    """Anonymize a Bearer token for telemetry. Salted HMAC-SHA256 when salt set."""
    if not token:
        return "anonymous"
    raw = token[7:].strip() if token.lower().startswith("bearer ") else token.strip()
    if not raw:
        return "anonymous"
    salt = settings.telemetry_hash_salt.encode("utf-8")
    if salt:
        digest = hmac.new(salt, raw.encode("utf-8"), hashlib.sha256).hexdigest()
    else:
        digest = hashlib.sha256(raw.encode("utf-8")).hexdigest()
    return digest[:16]


class TelemetryService:
    def __init__(self) -> None:
        self.enabled = settings.telemetry_enabled
        self._telemetry_logger: logging.Logger | None = None
        self._initialized = False

    def _ensure_logger(self) -> None:
        if self._initialized:
            return
        self._initialized = True
        if not self.enabled:
            return
        log_path = Path(settings.telemetry_log_path)
        log_path.parent.mkdir(parents=True, exist_ok=True)
        tlog = logging.getLogger("{{ project_slug }}_telemetry")
        tlog.setLevel(logging.INFO)
        tlog.propagate = False
        if not any(getattr(h, "_{{ project_slug }}_telemetry", False) for h in tlog.handlers):
            handler = logging.handlers.RotatingFileHandler(
                str(log_path),
                maxBytes=settings.telemetry_max_bytes,
                backupCount=settings.telemetry_backup_count,
            )
            handler._{{ project_slug }}_telemetry = True  # type: ignore[attr-defined]
            handler.setFormatter(logging.Formatter("%(message)s"))
            tlog.addHandler(handler)
            logger.info("Telemetry service initialised at %s", log_path)
        self._telemetry_logger = tlog

    async def record_event(self, event: TelemetryEvent) -> None:
        if not self.enabled:
            return
        try:
            self._ensure_logger()
            if self._telemetry_logger:
                self._telemetry_logger.info(event.model_dump_json(exclude_none=True))
        except Exception as e:  # never let telemetry crash the request
            logger.debug("Failed to record telemetry event: %s", e)


@lru_cache(maxsize=1)
def get_telemetry_service() -> TelemetryService:
    return TelemetryService()


# Back-compat module-level handle.
telemetry_service = get_telemetry_service()
