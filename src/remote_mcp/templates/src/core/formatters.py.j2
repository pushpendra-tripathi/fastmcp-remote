from __future__ import annotations

import logging

from src.core.errors import {{ class_prefix }}Error

logger = logging.getLogger(__name__)


def format_error(error: Exception) -> str:
    """Format an error for return to the MCP client.

    Known {{ class_prefix }}Error subclasses render their own user-facing message.
    Unknown exceptions return a generic message; the full traceback is logged.
    """
    if isinstance(error, {{ class_prefix }}Error):
        return error.to_mcp_string()
    logger.exception("Unexpected error in tool: %s", error)
    return (
        "❌ **Unexpected Error**\n\n"
        "Something went wrong on the server. Please try again. "
        "If the problem persists, contact support."
    )
