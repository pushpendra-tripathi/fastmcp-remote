"""{{ service_name }} MCP — FastMCP server instance and tool mounts.

Only responsible for:
  - Logging configuration (must run early, before any other import)
  - Creating the FastMCP instance with instructions
  - Mounting all tool and resource sub-routers

HTTP app wiring (Starlette, middleware, routes) lives in src/app.py.
"""

import logging
import logging.handlers
import os

from fastmcp import FastMCP

from src.config.settings import settings
from src.core.app_state import lifespan


def configure_logging() -> None:
    """Configure rotating file + console logging. Idempotent."""
    os.makedirs(settings.log_dir, exist_ok=True)
    root = logging.getLogger()
    root.setLevel(getattr(logging, settings.log_level.upper(), logging.INFO))

    if any(getattr(h, "_{{ project_slug }}", False) for h in root.handlers):
        return

    fmt = logging.Formatter(
        fmt="%(asctime)s [%(levelname)-8s] %(name)s %(message)s",
        datefmt="%Y-%m-%dT%H:%M:%S",
    )

    ch = logging.StreamHandler()
    ch.setFormatter(fmt)
    setattr(ch, "_{{ project_slug }}", True)
    root.addHandler(ch)

    fh = logging.handlers.RotatingFileHandler(
        os.path.join(settings.log_dir, "{{ project_slug }}_mcp.log"),
        maxBytes=10 * 1024 * 1024,
        backupCount=5,
    )
    fh.setFormatter(fmt)
    setattr(fh, "_{{ project_slug }}", True)
    root.addHandler(fh)


# ── FastMCP instance ──────────────────────────────────────────────────────────

mcp = FastMCP(
    "{{ service_name }}",
    instructions="""You are connected to the {{ service_name }} MCP server.

{{ service_name }} provides AI-native access to the {{ service_name }} API.

## Authentication
All tools require an OAuth Bearer token in the `Authorization: Bearer <token>` header.
The token is obtained via OAuth 2.0 from the {{ service_name }} Identity Provider.
""",
    lifespan=lifespan,
)

