"""RequireAuthMiddleware — OAuth Bearer token enforcement."""

from __future__ import annotations

import logging
from urllib.parse import urlsplit

import httpx
import jwt as pyjwt
from jwt import PyJWKClientError
from starlette.middleware.base import BaseHTTPMiddleware
from starlette.requests import Request
from starlette.responses import JSONResponse

from src.config.settings import settings
from src.core.auth import verify_jwt

logger = logging.getLogger(__name__)

# Exact-match paths that bypass auth. Add new public routes here.
_UNPROTECTED_EXACT = {"/", "/health"}
_UNPROTECTED_PREFIXES = ("/.well-known/", "/health/")
_PUBLIC_ASSETS = ("/favicon.ico", "/apple-touch-icon.png", "/android-chrome-")
_MCP_CONNECT_PATHS = {"/mcp"{% if legacy_sse %}, "/sse"{% endif %}}


def _is_unprotected(path: str) -> bool:
    if path in _UNPROTECTED_EXACT:
        return True
    if any(path.startswith(p) for p in _UNPROTECTED_PREFIXES):
        return True
    if any(path == a or path.startswith(a) for a in _PUBLIC_ASSETS):
        return True
    return False


def _resource_metadata_url() -> str:
    parts = urlsplit(settings.mcp_public_url)
    return f"{parts.scheme}://{parts.netloc}/.well-known/oauth-protected-resource"


def _unauthorized(message: str) -> JSONResponse:
    return JSONResponse(
        status_code=401,
        content={"error": message},
        headers={
            "WWW-Authenticate": f'Bearer resource_metadata="{_resource_metadata_url()}"'
        },
    )


def _origin_allowed(origin: str) -> bool:
    raw = (settings.allowed_origins or "").strip()
    if not raw or raw == "*":
        return True
    return origin in {o.strip() for o in raw.split(",") if o.strip()}


class RequireAuthMiddleware(BaseHTTPMiddleware):
    """
    HTTP-level middleware to enforce OAuth authentication.

    On the MCP GET handshake we additionally verify the token against the
    backend (via AUTH_PROBE_PATH) so mcp-remote sees a 401 immediately and
    triggers re-auth before expired tokens reach tools. Network errors during
    validation are treated as auth failures (fail-closed).
    """

    async def dispatch(self, request: Request, call_next):
        path = request.url.path

        origin = request.headers.get("origin")
        if origin and request.method != "OPTIONS" and not _origin_allowed(origin):
            logger.warning("Rejected disallowed Origin: %s", origin)
            return JSONResponse(status_code=403, content={"error": "Origin not allowed"})

        if _is_unprotected(path) or request.method == "OPTIONS":
            return await call_next(request)

        if settings.auth_mode == "none":
            return await call_next(request)

        auth_header = request.headers.get("authorization")
        if not auth_header:
            return _unauthorized(
                "Missing Authorization header. "
                "Token is required to access {{ service_name }} MCP."
            )

        if settings.auth_mode == "jwt":
            token = auth_header[7:].strip() if auth_header.lower().startswith("bearer ") else ""
            try:
                verify_jwt(token)
            except PyJWKClientError as e:
                # JWKS endpoint unreachable/misbehaving — infrastructure, not the
                # client's token. Mirror the auth-probe path: 503, fail-closed.
                logger.error("JWKS lookup failed during JWT verification: %s", e)
                return JSONResponse(
                    status_code=503,
                    content={"error": "Token validation unavailable."},
                )
            except pyjwt.PyJWTError as e:
                logger.warning("JWT verification failed: %s", e)
                return _unauthorized("Invalid or expired token.")

        if (
            request.method == "GET"
            and path.rstrip("/") in _MCP_CONNECT_PATHS
            and settings.auth_probe_enabled
        ):
            probe_url = f"{settings.api_base_url.rstrip('/')}{settings.auth_probe_path}"
            pooled = getattr(request.state, "http_client", None)
            try:
                if pooled is not None:
                    # Reuse the lifespan-pooled client; override base_url.
                    response = await pooled.get(
                        probe_url, headers={"Authorization": auth_header}, timeout=5.0
                    )
                else:
                    async with httpx.AsyncClient(timeout=5.0) as client:
                        response = await client.get(
                            probe_url, headers={"Authorization": auth_header}
                        )
                if response.status_code == 401:
                    logger.warning(
                        "Rejecting invalid/expired token during connection handshake."
                    )
                    return _unauthorized(
                        "Invalid or expired token. "
                        "Please authenticate again or refresh."
                    )
            except httpx.RequestError as e:
                logger.error("Network error validating token during handshake: %s", e)
                return JSONResponse(
                    status_code=503,
                    content={"error": "Token validation unavailable."},
                )

        return await call_next(request)
