from __future__ import annotations

from functools import lru_cache

from pydantic_settings import BaseSettings, SettingsConfigDict


class Settings(BaseSettings):
    # Backend
    api_base_url: str = "https://api.example.com"
    user_agent: str = "{{ project_slug }}-mcp/1.0"

    # Auth Probe — opt-in, validates token on SSE handshake
    auth_probe_path: str = "/health/"
    auth_probe_enabled: bool = False

    # OAuth / MCP discovery
    mcp_public_url: str = "http://localhost:8001/mcp"
    oauth_issuer_url: str = "http://localhost:8001"
    oauth_authorize_path: str = "/o/authorize/"
    oauth_token_path: str = "/o/token/"
    oauth_registration_path: str = "/o/register/"
    oauth_scopes_supported: str = "read"
    logo_uri: str = ""  # omitted from OAuth discovery response when empty

    # HTTP Client
    http_timeout: float = 90.0
    http_max_connections: int = 100
    http_max_keepalive: int = 20

    # Server
    host: str = "127.0.0.1"
    port: int = 8001
    log_level: str = "INFO"
    log_dir: str = "logs"
    allowed_origins: str = "https://claude.ai,https://chatgpt.com,https://cursor.sh"

    # Telemetry
    telemetry_enabled: bool = True
    telemetry_log_path: str = "logs/telemetry.jsonl"
    telemetry_max_bytes: int = 52428800  # 50 MB
    telemetry_backup_count: int = 10
    telemetry_hash_salt: str = ""  # HMAC salt for hash_token (set per-deployment)

    # Support / branding
    support_email: str = ""

    model_config = SettingsConfigDict(
        env_file=".env",
        env_file_encoding="utf-8",
        extra="ignore",
        case_sensitive=False,
    )


@lru_cache(maxsize=1)
def get_settings() -> Settings:
    return Settings()


# Back-compat module-level handle; equivalent to get_settings().
settings = get_settings()
