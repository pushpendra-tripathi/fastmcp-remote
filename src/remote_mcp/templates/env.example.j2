# {{ service_name }} MCP Server — Environment Variables

# ── Backend API ───────────────────────────────────────────────────────────────
API_BASE_URL=https://api.example.com

# Auth probe — endpoint that returns 401 for invalid tokens.
# Only used when AUTH_PROBE_ENABLED=true.
AUTH_PROBE_PATH=/health/
AUTH_PROBE_ENABLED=false

# Auth mode: none (dev only) | passthrough (default) | jwt (verify via JWKS)
AUTH_MODE={{ auth_mode }}
# Required when AUTH_MODE=jwt:
OAUTH_JWKS_URL=
# JWT audience claim to enforce (defaults to MCP_PUBLIC_URL when empty)
JWT_AUDIENCE=

# ── Server ────────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8001
LOG_LEVEL=INFO

# User agent for outbound HTTP requests
USER_AGENT={{ project_slug }}-mcp/1.0

# ── OAuth / MCP discovery ─────────────────────────────────────────────────────
MCP_PUBLIC_URL=http://localhost:8001/mcp
OAUTH_ISSUER_URL=http://localhost:8001

# OAuth endpoint paths (relative to OAUTH_ISSUER_URL, or full URLs).
# Defaults match Django-OAuth-Toolkit; override for other backends.
OAUTH_AUTHORIZE_PATH=/o/authorize/
OAUTH_TOKEN_PATH=/o/token/
OAUTH_REGISTRATION_PATH=/o/register/
OAUTH_SCOPES_SUPPORTED=read

# Optional: logo URI shown in OAuth discovery (leave empty to omit)
LOGO_URI=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated origins, or * for all
ALLOWED_ORIGINS=https://claude.ai,https://chatgpt.com,https://cursor.sh

# ── Telemetry ─────────────────────────────────────────────────────────────────
TELEMETRY_ENABLED=true
TELEMETRY_LOG_PATH=logs/telemetry.jsonl
# HMAC salt for user-id hashing — set a random 32+ byte value per deployment
TELEMETRY_HASH_SALT=

# ── Branding / Support ────────────────────────────────────────────────────────
# Shown as "Get Help" mailto link on the landing page. Leave empty to hide.
SUPPORT_EMAIL=
